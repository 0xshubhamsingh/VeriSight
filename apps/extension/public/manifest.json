{
  "manifest_version": 3,
  "name": "VeriSight MVP",
  "version": "0.1.0",
  "description": "AI-powered real-time fact verification overlays for web articles.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://*/*", "https://verisight-backend.frayquaza.workers.dev/*", "https://verisight-trust-engine.vercel.app/*"],
  "action": {
    "default_title": "VeriSight Dashboard",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

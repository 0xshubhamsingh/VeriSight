{
  "manifest_version": 3,
  "name": "VeriSight MVP",
  "version": "0.1.0",
  "description": "AI-powered real-time fact verification overlays for web articles.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://*/*", "http://localhost:8787/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
